---
/**
 * Proto Axiom site footer — ported from _export/primitives.jsx (PaFooter).
 * Uses .pa-footer* classes from design-system.css.
 */
const year = new Date().getFullYear();
---
<footer class="pa-footer">
  <div class="pa-wrap">
    <div class="pa-footer__grid">
      <div>
        <img
          class="pa-footer__logo"
          src="/brand/proto-axiom-logo_full-white-helix-blue.svg"
          alt="Proto Axiom"
        />
        <div class="pa-footer__addr">
          Suite 303, 80 Mount Street<br />
          North Sydney NSW 2060<br />
          Australia<br /><br />
          <a href="mailto:info@protoaxiom.com">info@protoaxiom.com</a>
        </div>
      </div>
      <div>
        <h5 class="pa-footer__h">Company</h5>
        <a class="pa-footer__link" href="/">Home</a>
        <a class="pa-footer__link" href="/team">Team</a>
        <a class="pa-footer__link" href="/contact">Contact</a>
      </div>
      <div>
        <h5 class="pa-footer__h">Investment</h5>
        <a class="pa-footer__link" href="/investment">Investment process</a>
        <a class="pa-footer__link" href="/#portfolio">Portfolio</a>
      </div>
      <div>
        <h5 class="pa-footer__h">Updates</h5>
        <a class="pa-footer__link" href="/news">News</a>
      </div>
      <div>
        <h5 class="pa-footer__h">Initiatives</h5>
        <a class="pa-footer__link" href="/applications/challenger">Challenger Summit</a>
        <a class="pa-footer__link" href="https://womenshealthfoundry.com.au" target="_blank" rel="noopener">
          Women's Health Foundry ↗
        </a>
      </div>
    </div>
    <div class="pa-footer__bottom">
      <span>© Proto Axiom {year}</span>
      <span>Australia</span>
    </div>
  </div>
</footer>
