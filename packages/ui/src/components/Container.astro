---
interface Props {
  as?: string;
  className?: string;
}
const { as: Tag = 'div', className = '' } = Astro.props;
---
<Tag class={`container ${className}`}>
  <slot />
</Tag>

<style>
  .container {
    width: 100%;
    max-width: var(--page-max);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }
</style>
