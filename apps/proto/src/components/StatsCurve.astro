---
/**
 * AUM stats — Direction 4 "Capital Curve" from Claude Design.
 * Hero figure (A$45M) + SVG comparing permanent capital vs 10-year fund decay,
 * with a "permanence dividend" delta band, fund-cliff marker, halo, and annotations.
 *
 * Settings baked in at the values Anthony shipped from the share preview:
 *   emphasis: 2, showDelta + showCliff + showHalo + showAnnotations all on.
 *
 * SVG paths pre-computed in this frontmatter rather than client-side JS so
 * the section renders statically with no JavaScript dependency.
 */

const W = 640, H = 240, P = 28;
const x = (t: number) => P + (t / 14) * (W - P * 2);
const y = (v: number) => H - 40 - v * (H - 80);
const e = 2; // emphasis = 2 (max)

const permPts: [number, number][] = [];
for (let t = 0; t <= 14; t += 0.2) {
  const base = 0.18 + 0.55 * Math.min(1, t / 6) + 0.04 * Math.sin(t * 0.55);
  const lifted = base + (0.05 * e * Math.min(1, t / 4));
  permPts.push([x(t), y(Math.min(0.97, lifted))]);
}
const fundPts: [number, number][] = [];
for (let t = 0; t <= 10.05; t += 0.15) {
  let v;
  if (t < 5) v = 0.15 + (0.55 + 0.05 * e) * (t / 5);
  else {
    const k = 1 + 0.6 * e;
    v = Math.max(0, (0.7 + 0.05 * e) * Math.pow(1 - (t - 5) / 5, k));
  }
  fundPts.push([x(t), y(v)]);
}
const toPath = (pts: [number, number][]) =>
  pts.map((p, i) => `${i ? 'L' : 'M'}${p[0].toFixed(1)},${p[1].toFixed(1)}`).join(' ');
const areaPath = (pts: [number, number][]) =>
  `${toPath(pts)} L${pts[pts.length - 1][0].toFixed(1)},${(H - 40).toFixed(1)} L${pts[0][0].toFixed(1)},${(H - 40).toFixed(1)} Z`;

const deltaTop = permPts.filter((p) => p[0] >= x(5));
const deltaBottomFund = fundPts.filter((p) => p[0] >= x(5));
const deltaBottomZero: [number, number][] = [];
for (let t = 10; t <= 14; t += 0.25) deltaBottomZero.push([x(t), y(0)]);
const deltaBottom = [...deltaBottomFund, ...deltaBottomZero];
const deltaPath = `${toPath(deltaTop)} ${deltaBottom.slice().reverse().map((p) => `L${p[0].toFixed(1)},${p[1].toFixed(1)}`).join(' ')} Z`;

const yearTicks = [0, 5, 10, 14];
const fundEndY = y(0);
const permEndY = permPts[permPts.length - 1][1];
const lineWidth = 2.25 + 0.75 * e;
---
<section class="pa-stats-section pa-stats-curve">
  <div class="pa-stats-section__wrap">
  <div class="pa-stats-curve__head">
    <div>
      <p class="pa-stats-eyebrow">The firm at a glance</p>
      <h2 class="pa-stats-h2">Permanent capital.<br/>Patient timelines.</h2>
    </div>
    <p class="pa-stats-lead">
      Proto Axiom is structured as a holding company, not a fund. No fixed life, no management fees, no carry — capital is deployed in milestone-gated tranches alongside founders and Australia's leading research institutions.
    </p>
  </div>

  <div class="pa-stats-curve__main">
    <div class="pa-stats-curve__hero">
      <div class="pa-stats-curve__hero-eyebrow">Capital deployed · 31 Mar 2026</div>
      <div class="pa-stats-curve__hero-num">
        <span class="pa-stats-curve__currency">A$</span>45M
      </div>
      <div class="pa-stats-curve__hero-lbl">Assets under management</div>
      <p class="pa-stats-curve__hero-sub">
        Permanent capital, milestone-gated. Held on a single balance sheet with no fund clock — capital is recycled into the portfolio as gates are cleared.
      </p>
    </div>

    <div class="pa-stats-curve__chart">
      <div class="pa-stats-curve__chart-head">
        <span>Capital available to portfolio · over time</span>
        <span>Illustrative</span>
      </div>

      <svg class="pa-stats-curve__chart-svg" viewBox={`0 0 ${W} ${H}`} aria-hidden="true">
        <defs>
          <linearGradient id="permFill" x1="0" x2="0" y1="0" y2="1">
            <stop offset="0%" stop-color="#00B3AB" stop-opacity={0.45 + 0.15 * e} />
            <stop offset="100%" stop-color="#00B3AB" stop-opacity="0.04" />
          </linearGradient>
          <linearGradient id="fundFill" x1="0" x2="0" y1="0" y2="1">
            <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.16" />
            <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0.02" />
          </linearGradient>
          <linearGradient id="deltaFill" x1="0" x2="1" y1="0" y2="0">
            <stop offset="0%" stop-color="#00B3AB" stop-opacity="0.10" />
            <stop offset="60%" stop-color="#00B3AB" stop-opacity="0.22" />
            <stop offset="100%" stop-color="#00B3AB" stop-opacity="0.30" />
          </linearGradient>
          <pattern id="deltaHatch" patternUnits="userSpaceOnUse" width="6" height="6" patternTransform="rotate(45)">
            <line x1="0" y1="0" x2="0" y2="6" stroke="#00B3AB" stroke-opacity="0.32" stroke-width="1.2" />
          </pattern>
          <filter id="permGlow" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur stdDeviation="3" />
          </filter>
        </defs>

        <line x1={P} y1={H - 40} x2={W - P} y2={H - 40} stroke="rgba(255,255,255,0.22)" stroke-width="1" />

        <line x1={x(10)} y1={28} x2={x(10)} y2={H - 40} stroke="rgba(255,255,255,0.32)" stroke-width="1" stroke-dasharray="3 4" />
        <text x={x(10)} y={20} fill="rgba(255,255,255,0.78)" font-size="10" font-family="Inter" letter-spacing="1.6" text-anchor="middle" font-weight="600">FUND CLOSE · Y10</text>

        <path d={areaPath(fundPts)} fill="url(#fundFill)" />
        <path d={toPath(fundPts)} fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" stroke-dasharray="4 4" />

        <path d={deltaPath} fill="url(#deltaFill)" />
        <path d={deltaPath} fill="url(#deltaHatch)" opacity={0.55 + 0.25 * e} />

        <path d={areaPath(permPts)} fill="url(#permFill)" />
        <path d={toPath(permPts)} fill="none" stroke="#00B3AB" stroke-width={lineWidth + 6} stroke-linecap="round" stroke-linejoin="round" opacity={0.18 + 0.12 * e} filter="url(#permGlow)" />
        <path d={toPath(permPts)} fill="none" stroke="#00B3AB" stroke-width={lineWidth} stroke-linecap="round" stroke-linejoin="round" />

        <line x1={x(10)} y1={fundEndY} x2={x(10) + 1} y2={H - 40} stroke="rgba(255,255,255,0.85)" stroke-width="1.5" stroke-dasharray="2 3" />
        <circle cx={x(10)} cy={fundEndY} r={3.5} fill="rgba(255,255,255,0.95)" />
        <circle cx={x(10)} cy={H - 40} r={3.5} fill="rgba(255,255,255,0.95)" />

        <circle cx={x(14)} cy={permEndY} r={4} fill="#00B3AB" />
        <path d={`M${(x(14) + 6).toFixed(1)},${permEndY.toFixed(1)} l10,5 l-10,5 z`} fill="#00B3AB" />

        <g transform={`translate(${x(10) + 6}, ${H - 56})`}>
          <text fill="#FFFFFF" font-size="11" font-family="Inter" font-weight="700" letter-spacing="-0.005em">A$0</text>
          <text y="13" fill="rgba(255,255,255,0.7)" font-size="9.5" font-family="Inter" letter-spacing="0.06em">FORCED EXIT</text>
        </g>
        <g transform={`translate(${x(13.2)}, ${(permEndY - 18).toFixed(1)})`} text-anchor="end">
          <text fill="#00B3AB" font-size="11" font-family="Inter" font-weight="700" letter-spacing="-0.005em">Still deploying</text>
          <text y="13" fill="rgba(0,179,171,0.85)" font-size="9.5" font-family="Inter" letter-spacing="0.06em">indefinite horizon →</text>
        </g>
        <g transform={`translate(${x(11.5)}, ${y(0.55).toFixed(1)})`} text-anchor="middle">
          <text fill="#00B3AB" font-size="10" font-family="Inter" font-weight="700" letter-spacing="0.08em">PERMANENCE</text>
          <text y="12" fill="#00B3AB" font-size="10" font-family="Inter" font-weight="700" letter-spacing="0.08em">DIVIDEND</text>
        </g>

        {yearTicks.map((t) => (
          <>
            <line x1={x(t)} y1={H - 40} x2={x(t)} y2={H - 36} stroke="rgba(255,255,255,0.32)" stroke-width="1" />
            <text x={x(t)} y={H - 18} fill="rgba(255,255,255,0.7)" font-size="11" font-family="Inter" text-anchor="middle" font-weight="600">{t === 14 ? '∞' : `Y${t}`}</text>
          </>
        ))}
      </svg>

      <div class="pa-stats-curve__chart-legend">
        <span><i class="--perm"></i> Proto Axiom · permanent capital</span>
        <span><i class="--fund"></i> 10-year closed-end fund</span>
      </div>
    </div>
  </div>

  <div class="pa-stats-curve__trio">
    <div class="pa-stats-curve__cell">
      <div class="pa-stats-curve__cell-num">8</div>
      <div class="pa-stats-curve__cell-lbl">Portfolio companies</div>
      <div class="pa-stats-curve__cell-sub">Seven formed with Proto Axiom as founding investor.</div>
    </div>
    <div class="pa-stats-curve__cell">
      <div class="pa-stats-curve__cell-num">3</div>
      <div class="pa-stats-curve__cell-lbl">In or approaching clinical trials</div>
      <div class="pa-stats-curve__cell-sub">Australian sites, sovereign capability.</div>
    </div>
    <div class="pa-stats-curve__cell">
      <div class="pa-stats-curve__cell-num">~30</div>
      <div class="pa-stats-curve__cell-lbl">Operating bench</div>
      <div class="pa-stats-curve__cell-sub">Science, clinical, finance and governance.</div>
    </div>
  </div>

  <div class="pa-stats-curve__foot">
    <span class="pa-stats-foot">As at 31 March 2026 · figures unaudited unless stated</span>
  </div>
  </div>
</section>
