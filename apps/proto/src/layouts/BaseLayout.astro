---
import '../styles/global.css';
import { Nav, Footer } from '@axiom/ui';

interface Props {
  title: string;
  description?: string;
  active?: string;
  darkNav?: boolean;
}
const {
  title,
  description = 'Proto Axiom — Australian biotech company creation platform.',
  active = 'home',
  darkNav = false,
} = Astro.props;
---
<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#375172" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={`https://protoaxiom.com${Astro.url.pathname}`} />

    <!-- Open Graph / social sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Proto Axiom" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://protoaxiom.com${Astro.url.pathname}`} />
    <meta property="og:image" content="https://protoaxiom.com/brand/proto-axiom-logo_full-standard.svg" />
    <meta property="og:locale" content="en_AU" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://protoaxiom.com/brand/proto-axiom-logo_full-standard.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <title>{title}</title>
  </head>
  <body class="pa-site">
    <Nav active={active} dark={darkNav} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  main { min-height: 60vh; }
</style>
