---
/**
 * Legacy /investment route — content moved to /thesis on 2026-05-03.
 *
 * The astro.config.mjs `redirects` entry maps /investment → /thesis at build
 * time and emits a meta-refresh page; this file is the page-level fallback
 * for crawlers that follow the page over the meta tag, and ensures the route
 * still resolves if the redirect config is ever toggled off.
 *
 * Do not add content here. Edit /thesis instead.
 */
const target = '/thesis';
const canonical = `https://protoaxiom.com${target}`;
---
<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting&hellip; | Proto Axiom</title>
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="noindex" />
    <style>
      body { font-family: system-ui, sans-serif; padding: 48px; color: #1D2A3A; }
      a { color: #00B3AB; }
    </style>
  </head>
  <body>
    <p>This page has moved. <a href={target}>Continue to {target}</a>.</p>
    <script is:inline>
      // Belt-and-braces client-side fallback for browsers that delay the
      // meta-refresh.
      window.location.replace('/thesis');
    </script>
  </body>
</html>
