---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Proto Axiom Connect | Proto Axiom"
  description="Join Proto Axiom Connect for early notice on Challenger Summit applications, Proto Axiom programmes and portfolio updates."
>
  <section class="pa-section pa-section--tight pa-section--white">
    <div class="pa-wrap">
      <div class="pa-page-head">
        <div>
          <div class="pa-eyebrow">Proto Axiom Connect</div>
          <h1 class="pa-page-head__h">Stay close to the work.</h1>
        </div>
        <p class="pa-page-head__lead">
          Proto Axiom Connect is our low‑frequency newsletter for researchers, founders and partners interested in Australian biotech company creation. Members receive early notice on Challenger Summit applications, programme updates and selected portfolio milestones — never spam, never shared.
        </p>
      </div>
    </div>
  </section>

  <section class="pa-section pa-section--almond">
    <div class="pa-wrap">
      <div style="max-width: 560px; margin: 0 auto; text-align: center;">
        <div class="pa-eyebrow">Register interest</div>
        <h2 class="pa-h2" style="margin: 16px 0 24px;">Join the list.</h2>
        <p class="pa-body" style="color: var(--pa-ink-muted); margin-bottom: 32px;">
          The Connect signup form is being finalised. While we set up the form, drop us an email and we'll add you to the list manually.
        </p>
        <a class="pa-btn pa-btn--primary" href="mailto:info@protoaxiom.com?subject=Proto%20Axiom%20Connect">
          Email info@protoaxiom.com <span class="pa-arrow">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
