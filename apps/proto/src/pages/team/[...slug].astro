---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const team = await getCollection('team');
  return team
    .filter((m) => m.data.name !== '_placeholder' && m.slug !== 'placeholder')
    .map((m) => ({ params: { slug: m.slug }, props: { entry: m } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const all = (await getCollection('team'))
  .filter((m) => m.data.name !== '_placeholder' && m.slug !== 'placeholder')
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
const idx = all.findIndex((m) => m.slug === entry.slug);
const prev = all[(idx - 1 + all.length) % all.length];
const next = all[(idx + 1) % all.length];
---
<BaseLayout title={`${entry.data.name} | Proto Axiom`} description={entry.data.title} active="team">
  <section class="pa-section pa-section--tight pa-section--white">
    <div class="pa-wrap">
      <a class="pa-bio__back" href="/team">&larr; All team</a>
      <div class="pa-bio__head">
        <div class="pa-bio__photo">
          {entry.data.photo ? (
            <img src={entry.data.photo} alt={entry.data.name} />
          ) : (
            <div class="pa-bio__photo-placeholder"></div>
          )}
        </div>
        <div class="pa-bio__intro">
          <div class="pa-eyebrow">Team</div>
          <h1 class="pa-bio__name">{entry.data.name}</h1>
          <p class="pa-bio__title">{entry.data.title}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="pa-section pa-section--white" style="padding-top: 32px;">
    <div class="pa-wrap">
      <div class="pa-bio__body">
        <Content />
      </div>
    </div>
  </section>

  <section class="pa-section pa-section--almond">
    <div class="pa-wrap">
      <nav class="pa-bio__pager" aria-label="Team navigation">
        <a href={`/team/${prev.slug}`} class="prev">
          <span class="label">Previous</span>
          <span class="name">{prev.data.name}</span>
        </a>
        <a href="/team" class="all">All team</a>
        <a href={`/team/${next.slug}`} class="next">
          <span class="label">Next</span>
          <span class="name">{next.data.name}</span>
        </a>
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .pa-bio__back {
    display: inline-block; font: 500 13px/1 var(--font-sans);
    color: var(--pa-ink-muted) !important; text-decoration: none !important;
    margin-bottom: 32px; padding-bottom: 4px;
    border-bottom: 1px solid transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }
  .pa-bio__back:hover { color: var(--pa-primary) !important; border-bottom-color: var(--pa-primary); }
  .pa-bio__head {
    display: grid; grid-template-columns: 280px 1fr; gap: 56px; align-items: end;
  }
  .pa-bio__photo {
    aspect-ratio: 4/5; background: var(--pa-light-almond); overflow: hidden;
    border-radius: 8px;
  }
  .pa-bio__photo img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.15); }
  .pa-bio__photo-placeholder { width: 100%; height: 100%; background: var(--pa-french-grey); }
  .pa-bio__name {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.4vw, 3.25rem); font-weight: 700;
    line-height: 1.05; letter-spacing: -0.02em;
    color: var(--pa-primary); margin: 16px 0 8px; text-wrap: balance;
  }
  .pa-bio__title {
    font: 400 19px/1.4 var(--font-sans); color: var(--pa-ink-muted);
    margin: 0; max-width: 50ch;
  }
  .pa-bio__body {
    max-width: 68ch; margin: 0 auto;
    font: 400 17px/1.7 var(--font-sans); color: var(--pa-ink);
  }
  .pa-bio__body :global(p) { margin: 0 0 1.25em; }
  .pa-bio__body :global(p:last-child) { margin-bottom: 0; }
  .pa-bio__body :global(strong) { color: var(--pa-primary); }
  .pa-bio__body :global(a) {
    color: var(--pa-accent-green); text-decoration: underline;
    text-decoration-thickness: 1px; text-underline-offset: 3px;
  }
  .pa-bio__pager {
    display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 32px;
    border-top: 1px solid var(--pa-hairline);
    border-bottom: 1px solid var(--pa-hairline);
    padding: 28px 0;
  }
  .pa-bio__pager a {
    display: flex; flex-direction: column; gap: 4px;
    text-decoration: none !important; color: var(--pa-ink) !important;
    font: 500 14px/1.3 var(--font-sans);
    transition: color 150ms ease;
  }
  .pa-bio__pager a:hover { color: var(--pa-primary) !important; }
  .pa-bio__pager .label {
    font: 500 11px/1 var(--font-sans); letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--pa-ink-subtle);
  }
  .pa-bio__pager .name { font-size: 16px; color: var(--pa-primary); }
  .pa-bio__pager .next { text-align: right; align-items: flex-end; }
  .pa-bio__pager .all {
    align-self: stretch; justify-content: center;
    padding: 12px 24px; border: 1px solid var(--pa-hairline); border-radius: 4px;
    font: 500 13px/1 var(--font-sans);
  }
  @media (max-width: 720px) {
    .pa-bio__head { grid-template-columns: 1fr; gap: 32px; align-items: start; }
    .pa-bio__photo { max-width: 280px; }
    .pa-bio__pager { grid-template-columns: 1fr; gap: 16px; }
    .pa-bio__pager .next { text-align: left; align-items: flex-start; }
  }
</style>
