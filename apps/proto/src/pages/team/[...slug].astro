---
/**
 * /team/[slug] — individual profile page.
 *
 * Two layouts driven by the member's primary section:
 *   editorial   → Management / Board (rich hero + side-rail + chips + pull-quote + affiliations)
 *   directory   → SAB / Strategic    (lean hero + areas/education rail)
 *
 * All layout, prose, attribution and metadata renders from the member's
 * frontmatter in apps/proto/src/content/team/*.md plus the markdown body.
 * Missing optional fields hide cleanly — fact-strip rows drop out, side-rail
 * blocks hide if empty, pull-quote and affiliations only render when present.
 *
 * Implementation of design handoff at /TeamMembersPersonalPage/Profile Pages.html.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import '@axiom/ui/profile.css';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const team = await getCollection('team');
  return team
    .filter((m) => m.data.name !== '_placeholder' && m.slug !== 'placeholder')
    .map((m) => ({ params: { slug: m.slug }, props: { entry: m } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// All members for cross-references and "more from..." carousel.
const all = (await getCollection('team'))
  .filter((m) => m.data.name !== '_placeholder' && m.slug !== 'placeholder');

type SectionKey = 'management' | 'board' | 'sab' | 'strategic';

const SECTION_INDEX: Record<SectionKey, { num: string; label: string }> = {
  management: { num: '01 / 04', label: 'Management' },
  board:      { num: '02 / 04', label: 'Board' },
  sab:        { num: '03 / 04', label: 'Scientific Advisory Board' },
  strategic:  { num: '04 / 04', label: 'Strategic Advisors' },
};

// Primary section = lowest-order section the member belongs to. Drives variant.
const sortedSections = [...entry.data.sections].sort((a, b) => a.order - b.order);
const primary = sortedSections[0].section as SectionKey;
const primaryMeta = SECTION_INDEX[primary];

// Cross-membership note: any sections other than primary
const otherSections = sortedSections.slice(1).map((s) => SECTION_INDEX[s.section as SectionKey].label);

// Variant — editorial for mgmt/board, directory-detail for sab/strategic
const isEditorial = primary === 'management' || primary === 'board';

// "More from this section" — sibling members in the SAME primary section, up to N
const siblings = all
  .filter((m) => m.slug !== entry.slug)
  .filter((m) => m.data.sections.some((s) => s.section === primary))
  .map((m) => {
    const cfg = m.data.sections.find((s) => s.section === primary)!;
    return { m, order: cfg.order };
  })
  .sort((a, b) => a.order - b.order);
const moreCount = isEditorial ? 3 : 4;
const more = siblings.slice(0, moreCount);

// Section line for fact strip ("Management · Board")
const sectionLine = sortedSections.map((s) => SECTION_INDEX[s.section as SectionKey].label).join(' · ');

// "At Proto Axiom" line — combine year + descriptor if present
const atPa = entry.data.joinedYear
  ? `Since ${entry.data.joinedYear}${entry.data.joinedDescriptor ? ' · ' + entry.data.joinedDescriptor : ''}`
  : null;

// Initials fallback for missing photos
function getInitials(name: string): string {
  return name.replace(/[,.].*$/, '').split(/\s+/).filter(Boolean).slice(0, 2)
    .map((p) => p[0]?.toUpperCase() ?? '').join('');
}
const initials = getInitials(entry.data.name);

// Description: prefer hook, fall back to title
const description = entry.data.hook ?? entry.data.title;
---

<BaseLayout
  title={`${entry.data.name} | Proto Axiom`}
  description={description}
  active="team"
  noHelix
>
  <div class:list={['pf', isEditorial ? 'pf--editorial' : 'pf--directory']}>

    {isEditorial ? (
      /* ============ EDITORIAL VARIANT ============ */
      <>
        <section class="pf__hero pf__section--white">
          <div class="pf__wrap">
            <a class="pf__back" href="/team">
              <span class="arr">←</span> All team
            </a>

            <div class="pf__hero-grid">
              <div class="pf__portrait">
                {entry.data.photo ? (
                  <img src={entry.data.photo} alt={entry.data.name} />
                ) : (
                  <div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:84px;color:#0d1a2e;opacity:.5">{initials}</div>
                )}
              </div>

              <div class="pf__hero-body">
                <div class="pf__crumbs">
                  <a href="/team">Team</a>
                  <span class="sep">/</span>
                  <a href="/team">{primaryMeta.label}</a>
                  <span class="sep">/</span>
                  <span class="cur">{entry.data.name}</span>
                </div>

                <div class="pf__sect-id">
                  <span class="num">{primaryMeta.num}</span>
                  <span class="bar"></span>
                  <span class="lbl">{primaryMeta.label}</span>
                  {entry.data.chair && <span class="chair">Chair</span>}
                </div>

                <h1 class="pf__name">{entry.data.name}</h1>
                <p class="pf__title"><em>{entry.data.title}</em></p>

                {entry.data.hook && <p class="pf__hook">{entry.data.hook}</p>}

                {(sectionLine || atPa || entry.data.based) && (
                  <dl class="pf__facts">
                    <div>
                      <dt>Section</dt>
                      <dd>{sectionLine}</dd>
                    </div>
                    {atPa && (
                      <div>
                        <dt>At Proto Axiom</dt>
                        <dd>{atPa}</dd>
                      </div>
                    )}
                    {entry.data.based && (
                      <div>
                        <dt>Based</dt>
                        <dd>{entry.data.based}</dd>
                      </div>
                    )}
                  </dl>
                )}

                {entry.data.chips && entry.data.chips.length > 0 && (
                  <div class="pf__chips">
                    <span class="pf__chip-lbl">Expertise</span>
                    {entry.data.chips.map((c) => <span class="pf__chip">{c}</span>)}
                  </div>
                )}
              </div>
            </div>
          </div>
        </section>

        <div class="pf__divider"></div>

        <section class="pf__section pf__section--white">
          <div class="pf__wrap">
            <div class="pf__body-grid">
              <aside class="pf__rail">
                {otherSections.length > 0 && (
                  <div class="pf__rail-block">
                    <div class="pf__rail-eyebrow">Cross-membership</div>
                    <p class="pf__rail-cross">
                      <em>Also serves on the {otherSections.join(' and ')} of Proto Axiom.</em>
                    </p>
                  </div>
                )}

                {entry.data.press && entry.data.press.length > 0 && (
                  <div class="pf__rail-block">
                    <div class="pf__rail-eyebrow">Press</div>
                    <ul class="pf__rail-list">
                      {entry.data.press.map((p) => (
                        <li><a href={p.url} target="_blank" rel="noopener">{p.label} <span class="ext">↗</span></a></li>
                      ))}
                    </ul>
                  </div>
                )}

                {entry.data.linkedin && (
                  <div class="pf__rail-block">
                    <div class="pf__rail-eyebrow">Connect</div>
                    <ul class="pf__rail-list">
                      <li><a href={entry.data.linkedin} target="_blank" rel="noopener">LinkedIn <span class="ext">↗</span></a></li>
                    </ul>
                  </div>
                )}
              </aside>

              <article class="pf__bio">
                <div class="pf__bio-eyebrow">Biography</div>
                <Content />

                {entry.data.pullQuote && (
                  <blockquote class="pf__pull">
                    <p>{entry.data.pullQuote.text}</p>
                    <footer>{entry.data.pullQuote.source}</footer>
                  </blockquote>
                )}

                {entry.data.affiliations && entry.data.affiliations.length > 0 && (
                  <div class="pf__affil">
                    <div class="pf__bio-eyebrow">Selected affiliations</div>
                    <ul>
                      {entry.data.affiliations.map((a) => (
                        <li><span class="role">{a.role}</span> <span class="org">{a.org}</span></li>
                      ))}
                    </ul>
                  </div>
                )}
              </article>
            </div>
          </div>
        </section>
      </>
    ) : (
      /* ============ DIRECTORY VARIANT ============ */
      <>
        <section class="pf__hero pf__hero--lean pf__section--white">
          <div class="pf__wrap">
            <a class="pf__back" href="/team">
              <span class="arr">←</span> All team
            </a>

            <div class="pf__lean-grid">
              <div class="pf__portrait pf__portrait--square">
                {entry.data.photo ? (
                  <img src={entry.data.photo} alt={entry.data.name} />
                ) : (
                  <div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:64px;color:#0d1a2e;opacity:.5">{initials}</div>
                )}
              </div>

              <div class="pf__lean-body">
                <div class="pf__crumbs">
                  <a href="/team">Team</a>
                  <span class="sep">/</span>
                  <a href="/team">{primaryMeta.label}</a>
                  <span class="sep">/</span>
                  <span class="cur">{entry.data.name}</span>
                </div>

                <div class="pf__sect-id">
                  <span class="num">{primaryMeta.num}</span>
                  <span class="bar"></span>
                  <span class="lbl">{primaryMeta.label}</span>
                  {entry.data.chair && <span class="chair">Chair</span>}
                </div>

                <h1 class="pf__name">{entry.data.name}</h1>
                <p class="pf__title"><em>{entry.data.title}</em></p>

                {(entry.data.institution || entry.data.caption) && (
                  <p class="pf__institutions">
                    <span class="pf__inst">
                      {entry.data.institution ?? entry.data.caption}
                    </span>
                  </p>
                )}
              </div>
            </div>
          </div>
        </section>

        <div class="pf__divider"></div>

        <section class="pf__section pf__section--white">
          <div class="pf__wrap">
            <div class="pf__lean-body-grid">
              <div class="pf__lean-rail">
                {entry.data.areas && entry.data.areas.length > 0 && (
                  <>
                    <div class="pf__rail-eyebrow">Areas</div>
                    <ul class="pf__lean-areas">
                      {entry.data.areas.map((a) => <li>{a}</li>)}
                    </ul>
                  </>
                )}
                {entry.data.education && (
                  <>
                    <div class="pf__rail-eyebrow" style="margin-top: 32px;">Education</div>
                    <p class="pf__lean-edu" set:html={entry.data.education.replace(/\n/g, '<br />')}></p>
                  </>
                )}
                {entry.data.linkedin && (
                  <>
                    <div class="pf__rail-eyebrow" style="margin-top: 32px;">Connect</div>
                    <ul class="pf__rail-list" style="margin-top: 12px;">
                      <li><a href={entry.data.linkedin} target="_blank" rel="noopener">LinkedIn <span class="ext">↗</span></a></li>
                    </ul>
                  </>
                )}
              </div>

              <article class="pf__bio">
                <div class="pf__bio-eyebrow">Biography</div>
                <Content />
              </article>
            </div>
          </div>
        </section>
      </>
    )}

    {/* ============ MORE FROM THIS SECTION ============ */}
    {more.length > 0 && (
      <section class="pf__section pf__section--almond">
        <div class="pf__wrap">
          <div class="pf__more-head">
            <div class="pf__sect-id">
              <span class="num">{primaryMeta.num}</span>
              <span class="bar"></span>
              <span class="lbl">{primaryMeta.label}</span>
            </div>
            <h2 class="pf__more-h">More from the <em>{primaryMeta.label.toLowerCase()}.</em></h2>
            <a class="pf__more-all" href="/team">All team →</a>
          </div>

          <div class:list={['pf__more-grid', !isEditorial && 'pf__more-grid--4']}>
            {more.map((s) => (
              <a class="pf__more-card" href={`/team/${s.m.slug}`}>
                <div class="pf__more-photo">
                  {s.m.data.photo ? (
                    <img src={s.m.data.photo} alt={s.m.data.name} />
                  ) : (
                    <div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:42px;color:#0d1a2e;opacity:.5">{getInitials(s.m.data.name)}</div>
                  )}
                </div>
                <h3 class="pf__more-name">{s.m.data.name}</h3>
                <div class="pf__more-title">{s.m.data.title}</div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </div>
</BaseLayout>
