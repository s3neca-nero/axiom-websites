         §13 — DEEP NAVY: WHAT COULD BE WRONG
         ================================================================== -->
    <section id="section-13" class="tx-section tx-section--deep">
      <svg class="tx-helix tx-helix--deep" viewBox="0 0 400 800" fill="none" aria-hidden="true">
        <g stroke="#00B3AB" stroke-width="1.2" fill="none">
