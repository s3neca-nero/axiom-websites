<script is:inline>
  // TOC active state + reveal-on-scroll for opted-in elements.
  // Idempotent: guards against multiple runs.
  (function () {
    if (window.__paThesisInit) return;
    window.__paThesisInit = true;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const tocItems = document.querySelectorAll('.tx-toc__item');
    const sections = document.querySelectorAll('.tx-page section[id^="section-"]');

    if ('IntersectionObserver' in window) {
      const tocObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            tocItems.forEach((it) => {
              it.classList.toggle('is-active', it.getAttribute('href') === '#' + id);
            });
          }
        });
      }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });
      sections.forEach((s) => tocObs.observe(s));

      if (!reduced) {
        const reveals = document.querySelectorAll('.tx-reveal');
        const revObs = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-in');
              revObs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15 });
        reveals.forEach((el) => revObs.observe(el));
      }
    }
  })();
</script>
