---
// Proto Axiom — Landing splash
// Self-contained, full-viewport hero with helix → constellation → helix animation.
// Uses the shared SiteMenu (variant=dark, current=home so Home is hidden).
import { SiteMenu } from '@axiom/ui';

const title = 'Proto Axiom';
const description =
  'Proto Axiom — Australian biotech company creation. Eight portfolio companies. Permanent capital. Pharma-grade execution.';
const canonical = `https://protoaxiom.com${Astro.url.pathname}`;
const ogImage = 'https://protoaxiom.com/brand/proto-axiom-logo_full-standard.svg';
---
<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a1320" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Proto Axiom" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_AU" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts: Cormorant Garamond (display) + DM Sans (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div id="stage">
      <canvas id="canvas"></canvas>
      <div class="vignette"></div>
      <div class="grain"></div>
      <SiteMenu variant="dark" current="home" />
      <div class="copy">
        <h1 class="headline">
          We build the companies <span class="em">we invest in.</span>
        </h1>
        <p class="subline">
          Australian science <span class="dot"></span> Pharma-grade execution
        </p>
      </div>
      <div class="corner">Sydney · est. 2021</div>
    </div>

    <script is:inline src="https://unpkg.com/three@0.160.0/build/three.min.js"></script>
    <script is:inline>
      (() => {
        const canvas = document.getElementById('canvas');
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setClearColor(0x0a1320, 1);

        const scene = new THREE.Scene();
        scene.fog = new THREE.FogExp2(0x0a1320, 0.06);

        const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 100);
        camera.position.set(0, 0, 14);

        function resize() {
          const w = window.innerWidth, h = window.innerHeight;
          renderer.setSize(w, h, false);
          camera.aspect = w / h;
          camera.updateProjectionMatrix();
        }
        window.addEventListener('resize', resize);
        resize();

        const PARTICLE_COUNT = 2000;
        const NODES = 8;
        const HELIX_TURNS = 4;
        const HELIX_HEIGHT = 9.5;
        const HELIX_RADIUS = 1.8;

        const helixPos = new Float32Array(PARTICLE_COUNT * 3);
        const constellationPos = new Float32Array(PARTICLE_COUNT * 3);
        const seed = new Float32Array(PARTICLE_COUNT);

        const nodeAnchors = [];
        for (let i = 0; i < NODES; i++) {
          const t = (i + 0.5) / NODES;
          const phi = Math.acos(1 - 2 * t);
          const theta = Math.PI * (1 + Math.sqrt(5)) * i;
          const r = 4.2;
          nodeAnchors.push(new THREE.Vector3(
            r * Math.sin(phi) * Math.cos(theta),
            (t - 0.5) * 7.5,
            r * Math.sin(phi) * Math.sin(theta) * 0.7
          ));
        }

        for (let i = 0; i < PARTICLE_COUNT; i++) {
          const strand = i % 2;
          const u = i / PARTICLE_COUNT;
          const angle = u * HELIX_TURNS * Math.PI * 2 + strand * Math.PI;
          const y = (u - 0.5) * HELIX_HEIGHT;
          const rJit = HELIX_RADIUS + (Math.random() - 0.5) * 0.08;
          helixPos[i*3+0] = Math.cos(angle) * rJit;
          helixPos[i*3+1] = y;
          helixPos[i*3+2] = Math.sin(angle) * rJit;

          const nodeIdx = i % NODES;
          const anchor = nodeAnchors[nodeIdx];
          const k = Math.pow(Math.random(), 2.4);
          const spread = 0.05 + k * 1.6;
          const dir = new THREE.Vector3(
            (Math.random() - 0.5),
            (Math.random() - 0.5),
            (Math.random() - 0.5)
          ).normalize().multiplyScalar(spread);
          constellationPos[i*3+0] = anchor.x + dir.x;
          constellationPos[i*3+1] = anchor.y + dir.y;
          constellationPos[i*3+2] = anchor.z + dir.z;

          seed[i] = Math.random();
        }

        const positions = new Float32Array(PARTICLE_COUNT * 3);
        positions.set(helixPos);

        const geom = new THREE.BufferGeometry();
        geom.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        geom.setAttribute('aSeed', new THREE.BufferAttribute(seed, 1));

        const uniforms = {
          uTime: { value: 0 },
          uPixelRatio: { value: renderer.getPixelRatio() },
          uColorA: { value: new THREE.Color('#00B3AB') },
          uColorB: { value: new THREE.Color('#7fe9e3') },
          uMorph: { value: 0 },
          // Cursor proximity — particles near the cursor get a soft glow + size boost.
          uCursorWorld: { value: new THREE.Vector3(1e3, 1e3, 1e3) }, // off-screen sentinel
          uCursorIntensity: { value: 0 },
          // Click pulse — a radial ripple expands outward from the click point.
          uPulseOrigin: { value: new THREE.Vector3(1e3, 1e3, 1e3) },
          uPulseStrength: { value: 0 }
        };

        const pointsMat = new THREE.ShaderMaterial({
          uniforms,
          transparent: true,
          depthWrite: false,
          blending: THREE.AdditiveBlending,
          vertexShader: `
            attribute float aSeed;
            uniform float uTime;
            uniform float uPixelRatio;
            uniform float uMorph;
            uniform vec3  uCursorWorld;
            uniform float uCursorIntensity;
            uniform vec3  uPulseOrigin;
            uniform float uPulseStrength;
            varying float vGlow;
            varying float vSeed;
            void main() {
              vSeed = aSeed;
              vec3 p = position;
              float breathe = sin(uTime * 0.6 + aSeed * 6.2831) * 0.04;
              p += normalize(p + 0.0001) * breathe;

              // Particle's world-space position (modelMatrix accounts for rotation).
              vec3 pWorld = (modelMatrix * vec4(p, 1.0)).xyz;

              // Cursor proximity — soft Gaussian falloff, scaled by intensity (which
              // ramps to 1 while the pointer is over the canvas, decays to 0 on leave).
              float cursorD2 = dot(pWorld - uCursorWorld, pWorld - uCursorWorld);
              float cursorBoost = exp(-cursorD2 * 0.42) * uCursorIntensity;

              // Click pulse — a thin band that expands outward from uPulseOrigin as
              // uPulseStrength fades from 1 to 0. Particles intersecting the band get
              // a one-shot size+brightness boost.
              float pulseRadius = (1.0 - uPulseStrength) * 8.0;
              float pulseD = distance(pWorld, uPulseOrigin);
              float bandDelta = (pulseD - pulseRadius) * (pulseD - pulseRadius);
              float pulseBoost = exp(-bandDelta * 0.55) * uPulseStrength;

              vec4 mv = modelViewMatrix * vec4(p, 1.0);
              float dist = -mv.z;
              float flicker = 0.65 + 0.35 * sin(uTime * 1.4 + aSeed * 12.566);
              vGlow = mix(0.55, 1.15, uMorph) * flicker + cursorBoost * 0.65 + pulseBoost * 1.4;
              float size = mix(2.2, 4.4, uMorph) * uPixelRatio * (8.0 / max(dist, 0.0001));
              size += cursorBoost * 2.0 + pulseBoost * 5.0;
              gl_PointSize = clamp(size, 1.0, 36.0);
              gl_Position = projectionMatrix * mv;
            }
          `,
          fragmentShader: `
            uniform vec3 uColorA;
            uniform vec3 uColorB;
            varying float vGlow;
            varying float vSeed;
            void main() {
              vec2 uv = gl_PointCoord - 0.5;
              float d = length(uv);
              if (d > 0.5) discard;
              float core = smoothstep(0.5, 0.0, d);
              float halo = pow(core, 2.4);
              vec3 col = mix(uColorA, uColorB, vSeed * 0.6 + 0.2) * vGlow;
              float a = halo;
              gl_FragColor = vec4(col, a);
            }
          `
        });

        const points = new THREE.Points(geom, pointsMat);
        scene.add(points);

        const lineSegs = [];
        for (let i = 0; i < NODES; i++) {
          const dists = nodeAnchors.map((p, j) => ({ j, d: i === j ? Infinity : nodeAnchors[i].distanceTo(p) }));
          dists.sort((a,b) => a.d - b.d);
          lineSegs.push([i, dists[0].j]);
          lineSegs.push([i, dists[1].j]);
        }
        const seen = new Set();
        const edges = [];
        for (const [a,b] of lineSegs) {
          const key = a < b ? `${a}-${b}` : `${b}-${a}`;
          if (seen.has(key)) continue;
          seen.add(key);
          edges.push([a,b]);
        }
        const linePos = new Float32Array(edges.length * 2 * 3);
        for (let e = 0; e < edges.length; e++) {
          const [a,b] = edges[e];
          linePos[e*6+0] = nodeAnchors[a].x;
          linePos[e*6+1] = nodeAnchors[a].y;
          linePos[e*6+2] = nodeAnchors[a].z;
          linePos[e*6+3] = nodeAnchors[b].x;
          linePos[e*6+4] = nodeAnchors[b].y;
          linePos[e*6+5] = nodeAnchors[b].z;
        }
        const lineGeom = new THREE.BufferGeometry();
        lineGeom.setAttribute('position', new THREE.BufferAttribute(linePos, 3));
        const lineMat = new THREE.LineBasicMaterial({
          color: 0x00B3AB,
          transparent: true,
          opacity: 0.0,
          blending: THREE.AdditiveBlending,
          depthWrite: false
        });
        const lines = new THREE.LineSegments(lineGeom, lineMat);
        scene.add(lines);

        const nodeHaloGeom = new THREE.BufferGeometry();
        const nodeHaloPos = new Float32Array(NODES * 3);
        for (let i = 0; i < NODES; i++) {
          nodeHaloPos[i*3+0] = nodeAnchors[i].x;
          nodeHaloPos[i*3+1] = nodeAnchors[i].y;
          nodeHaloPos[i*3+2] = nodeAnchors[i].z;
        }
        nodeHaloGeom.setAttribute('position', new THREE.BufferAttribute(nodeHaloPos, 3));
        const haloUniforms = {
          uTime: { value: 0 },
          uPixelRatio: { value: renderer.getPixelRatio() },
          uOpacity: { value: 0 },
          uColor: { value: new THREE.Color('#7fe9e3') }
        };
        const haloMat = new THREE.ShaderMaterial({
          uniforms: haloUniforms,
          transparent: true,
          depthWrite: false,
          blending: THREE.AdditiveBlending,
          vertexShader: `
            uniform float uTime;
            uniform float uPixelRatio;
            varying float vT;
            void main() {
              vec4 mv = modelViewMatrix * vec4(position, 1.0);
              float dist = -mv.z;
              float pulse = 0.85 + 0.15 * sin(uTime * 1.2 + position.x * 1.7 + position.y * 0.9);
              vT = pulse;
              gl_PointSize = (16.0 * uPixelRatio * pulse) * (8.0 / max(dist, 0.0001));
              gl_Position = projectionMatrix * mv;
            }
          `,
          fragmentShader: `
            uniform float uOpacity;
            uniform vec3 uColor;
            varying float vT;
            void main() {
              vec2 uv = gl_PointCoord - 0.5;
              float d = length(uv);
              if (d > 0.5) discard;
              float core = smoothstep(0.5, 0.0, d);
              float a = pow(core, 2.0) * uOpacity * vT;
              gl_FragColor = vec4(uColor, a);
            }
          `
        });
        const haloPoints = new THREE.Points(nodeHaloGeom, haloMat);
        scene.add(haloPoints);

        const target = { x: 0, y: 0 };
        const cur = { x: 0, y: 0 };

        // Project a screen-space cursor (clientX/Y) onto the helix's z=0 plane in
        // world space. This is what the vertex shader uses for cursor proximity
        // and click-pulse effects so particles are highlighted in their actual 3D
        // neighbourhood, not just by screen coordinates.
        const cursorTmp = new THREE.Vector3();
        function projectCursorToHelixPlane(clientX, clientY) {
          const ndcX = (clientX / window.innerWidth) * 2 - 1;
          const ndcY = -((clientY / window.innerHeight) * 2 - 1);
          cursorTmp.set(ndcX, ndcY, 0.5).unproject(camera);
          cursorTmp.sub(camera.position).normalize();
          const denom = cursorTmp.z !== 0 ? cursorTmp.z : 1e-6;
          const t = -camera.position.z / denom;
          return new THREE.Vector3()
            .copy(cursorTmp)
            .multiplyScalar(t)
            .add(camera.position);
        }

        let cursorIntensityTarget = 0;
        let pulseStartT = -1;
        const PULSE_DURATION = 0.9;

        window.addEventListener('pointermove', (e) => {
          target.x = (e.clientX / window.innerWidth) * 2 - 1;
          target.y = (e.clientY / window.innerHeight) * 2 - 1;
          uniforms.uCursorWorld.value.copy(projectCursorToHelixPlane(e.clientX, e.clientY));
          cursorIntensityTarget = 1;
        });
        window.addEventListener('pointerleave', () => {
          target.x = 0; target.y = 0;
          cursorIntensityTarget = 0;
        });
        // Click anywhere on the splash to send a teal pulse outward from that point.
        // Suppressed under prefers-reduced-motion — the resting helix carries the
        // page's intent on its own.
        window.addEventListener('pointerdown', (e) => {
          if (reducedMotion) return;
          // Ignore clicks on UI (the SiteMenu sits above the canvas).
          const el = e.target;
          if (el && el.closest && el.closest('[data-pa-sitemenu]')) return;
          uniforms.uPulseOrigin.value.copy(projectCursorToHelixPlane(e.clientX, e.clientY));
          pulseStartT = (performance.now() - t0) / 1000;
        });

        const CYCLE = 16.0;
        function smoothstep(a, b, t) {
          t = Math.max(0, Math.min(1, (t - a) / (b - a)));
          return t * t * (3 - 2 * t);
        }

        const positionsAttr = geom.getAttribute('position');
        let t0 = performance.now();
        // Smoothed cursor intensity (eased toward target each frame so hover/leave
        // don't snap on/off).
        let cursorIntensityCur = 0;
        function tick() {
          const now = performance.now();
          const t = (now - t0) / 1000;
          uniforms.uTime.value = t;
          haloUniforms.uTime.value = t;

          // Cursor intensity ease — 0.05 per-frame is roughly a 200ms ramp at 60fps.
          cursorIntensityCur += (cursorIntensityTarget - cursorIntensityCur) * 0.05;
          uniforms.uCursorIntensity.value = cursorIntensityCur;

          // Click pulse — quadratic ease-out fade over PULSE_DURATION seconds.
          if (pulseStartT >= 0) {
            const pulseElapsed = t - pulseStartT;
            if (pulseElapsed >= PULSE_DURATION) {
              uniforms.uPulseStrength.value = 0;
              pulseStartT = -1;
            } else {
              const k = 1 - pulseElapsed / PULSE_DURATION;
              uniforms.uPulseStrength.value = k * k;
            }
          }

          const phase = (t % CYCLE) / CYCLE;
          let morph = 0;
          if (phase < 0.42) morph = smoothstep(0.18, 0.42, phase);
          else if (phase < 0.58) morph = 1;
          else if (phase < 0.82) morph = 1 - smoothstep(0.58, 0.82, phase);
          else morph = 0;

          if (reducedMotion) morph = 0;

          uniforms.uMorph.value = morph;
          lineMat.opacity = morph * 0.28;
          haloUniforms.uOpacity.value = morph * 0.9;

          const transition = morph * (1 - morph) * 4;
          for (let i = 0; i < PARTICLE_COUNT; i++) {
            const ix = i*3;
            const hx = helixPos[ix], hy = helixPos[ix+1], hz = helixPos[ix+2];
            const cx = constellationPos[ix], cy = constellationPos[ix+1], cz = constellationPos[ix+2];
            const s = seed[i];
            const localMorph = Math.max(0, Math.min(1, morph + (s - 0.5) * 0.18));
            const e = localMorph * localMorph * (3 - 2 * localMorph);
            const noise = transition * 0.25 * Math.sin(t * 0.8 + s * 12.566);
            positions[ix]   = hx + (cx - hx) * e + noise * 0.1;
            positions[ix+1] = hy + (cy - hy) * e;
            positions[ix+2] = hz + (cz - hz) * e + noise * 0.1;
          }
          positionsAttr.needsUpdate = true;

          const rotSpeed = reducedMotion ? 0 : (0.10 - morph * 0.07);
          points.rotation.y += rotSpeed * 0.016;
          lines.rotation.y = points.rotation.y;
          haloPoints.rotation.y = points.rotation.y;

          points.rotation.x = reducedMotion ? 0 : Math.sin(t * 0.15) * 0.06;
          lines.rotation.x = points.rotation.x;
          haloPoints.rotation.x = points.rotation.x;

          cur.x += (target.x - cur.x) * 0.04;
          cur.y += (target.y - cur.y) * 0.04;
          camera.position.x = cur.x * 0.9;
          camera.position.y = -cur.y * 0.6;
          camera.lookAt(0, 0, 0);

          renderer.render(scene, camera);
          requestAnimationFrame(tick);
        }

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            document.body.classList.add('ready');
            tick();
          });
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg-0: #0a1320;
    --bg-1: #0e1b2c;
    --navy: #375172;
    --teal: #00B3AB;
    --teal-bright: #33d6cf;
    --white: #ffffff;
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    background: var(--bg-0);
    color: var(--white);
    font-family: 'DM Sans', system-ui, sans-serif;
    overflow: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  #stage {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
  }
  #canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  .vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 50% 45%, rgba(10,19,32,0) 0%, rgba(10,19,32,0.35) 60%, rgba(10,19,32,0.85) 100%);
    z-index: 1;
  }
  .grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.04;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)' opacity='0.9'/></svg>");
    z-index: 2;
  }

  .copy {
    position: absolute;
    left: 48px;
    bottom: 80px;
    max-width: 760px;
    z-index: 3;
  }
  .headline {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-weight: 400;
    font-size: clamp(40px, 5.6vw, 72px);
    line-height: 1.04;
    letter-spacing: -0.01em;
    color: var(--white);
    margin: 0 0 22px 0;
    text-wrap: balance;
  }
  .headline .em {
    font-style: italic;
    font-weight: 300;
  }
  .subline {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.55;
    letter-spacing: 0.005em;
    color: rgba(255,255,255,0.7);
    margin: 0;
    max-width: 460px;
  }
  .subline .dot {
    display: inline-block;
    width: 3px;
    height: 3px;
    border-radius: 999px;
    background: var(--teal);
    vertical-align: middle;
    margin: 0 10px 2px 10px;
    opacity: 0.85;
  }

  .corner {
    position: absolute;
    bottom: 32px;
    right: 48px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    z-index: 3;
  }

  /* Entrance animation — fade in once particles ready */
  .copy, .corner {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 1200ms cubic-bezier(0.2,0.7,0.2,1), transform 1200ms cubic-bezier(0.2,0.7,0.2,1);
  }
  body.ready .copy,
  body.ready .corner {
    opacity: 1;
    transform: translateY(0);
  }
  body.ready .copy { transition-delay: 300ms; }
  body.ready .corner { transition-delay: 600ms; }

  @media (max-width: 720px) {
    .copy { left: 24px; right: 24px; bottom: 56px; }
    .corner { right: 24px; bottom: 20px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .copy, .corner {
      transition: opacity 200ms linear;
      transform: none;
    }
  }
</style>
