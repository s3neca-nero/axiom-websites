---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatsCurve from '../components/StatsCurve.astro';
import '@axiom/ui/stats-curve.css';
import { hero, stats, buildSteps, portfolio, news } from '../data/site';

const universities = [
  'University of Sydney',
  'UNSW Sydney',
  'Monash University',
  'Griffith University',
  'ANZAC Research Institute',
  'Sydney Local Health District',
];

---
<BaseLayout title="Proto Axiom — Australian biotech company creation" active="home">
  <!-- Hero (variant A) -->
  <section class="pa-hero-a">
    <div class="pa-wrap">
      <div class="pa-hero-a__stamp">
        <span>EST. 2021 · SYDNEY</span>
        <span class="dot"></span>
        <span>HOLDING COMPANY · PERMANENT CAPITAL</span>
        <span class="dot"></span>
        <span>A$45M AUM · 8 PORTFOLIO COMPANIES</span>
      </div>
      <div class="pa-hero-a__grid">
        <div class="pa-hero-a__head">
          <div class="pa-eyebrow">{hero.eyebrow}</div>
          <h1 class="pa-hero-a__title">
            We build biotech companies <em>in Australia.</em>
          </h1>
          <p class="pa-hero-a__lead">{hero.lead}</p>
          <div class="pa-hero-a__cta">
            <a class="pa-btn pa-btn--primary" href="/investment">
              Our investment process <span class="pa-arrow">→</span>
            </a>
            <a class="pa-btn pa-btn--ghost" href="/#portfolio">View portfolio</a>
          </div>
        </div>
        <div class="pa-hero-a__visual">
          <img
            src="/images/photography/cogger-hunt-endo-axiom.jpg"
            alt="Prof Victoria Cogger and A/Prof Nicholas Hunt, co-founders of Endo Axiom, in the lab"
          />
          <div class="pa-hero-a__caption">
            INSIDE THE LAB · ENDO AXIOM · CO‑FOUNDERS PROF VICTORIA COGGER &amp; A/PROF NICHOLAS HUNT
          </div>
        </div>
      </div>
      <div class="pa-unis">
        <div class="pa-unis__head">
          <div class="pa-unis__lbl">Sourced with</div>
          <h4 class="pa-unis__h">Australia's leading research institutions and the public health system.</h4>
        </div>
        <div class="pa-unis__grid">
          {universities.map((u) => <div class="pa-unis__cell">{u}</div>)}
        </div>
      </div>
    </div>
  </section>

  <!-- AUM stats — Capital Curve direction -->
  <StatsCurve />


  <!-- Capital strip -->
  <section class="pa-section pa-section--tight pa-section--white" style="padding-top: 0;">
    <div class="pa-wrap">
      <div class="pa-capital-quiet">
        <div class="pa-capital-quiet__lbl">Capital base</div>
        <p class="pa-capital-quiet__body">
          Backed by a closed group of <strong>33 private investors</strong> across Australia, the United States and the United Kingdom — family offices, foundations and strategic operators who provide patient capital alongside operating insight. Investor identities held in confidence.
        </p>
      </div>
    </div>
  </section>

  <!-- Why Australia -->
  <section class="pa-section pa-section--almond">
    <div class="pa-wrap">
      <div class="pa-whyx">
        <header class="pa-whyx__head">
          <div>
            <div class="pa-eyebrow">The translation gap</div>
            <h2 class="pa-h2" style="margin: 0;">World‑class science.<br/>Under‑capitalised companies.</h2>
          </div>
          <p class="pa-whyx__lead">
            Australia consistently ranks in the global top tier for biomedical research output — but the capital flowing into translation lags every comparable economy. The arithmetic is the entire reason Proto Axiom exists.
          </p>
        </header>
        <div class="pa-whyx__compare">
          <div class="pa-whyx__compare-head">
            <div class="pa-whyx__compare-lbl">Per‑researcher venture capital, life sciences</div>
            <div class="pa-whyx__compare-note">Source: AusBiotech, OECD MSTI, NVCA · 2024 calendar year</div>
          </div>
          <div class="pa-whyx__compare-rows">
            <div class="pa-whyx__compare-row">
              <div class="pa-whyx__compare-flag">AU</div>
              <div class="pa-whyx__compare-bar"><span style="width: 8%;"></span></div>
              <div class="pa-whyx__compare-val">US$11k</div>
            </div>
            <div class="pa-whyx__compare-row">
              <div class="pa-whyx__compare-flag">UK</div>
              <div class="pa-whyx__compare-bar"><span style="width: 34%;"></span></div>
              <div class="pa-whyx__compare-val">US$48k</div>
            </div>
            <div class="pa-whyx__compare-row">
              <div class="pa-whyx__compare-flag pa-whyx__compare-flag--accent">US</div>
              <div class="pa-whyx__compare-bar"><span class="pa-whyx__compare-bar-fill--accent" style="width: 100%;"></span></div>
              <div class="pa-whyx__compare-val pa-whyx__compare-val--accent">US$142k</div>
            </div>
          </div>
        </div>
        <div class="pa-whyx__stats">
          <div class="pa-whyx__stat">
            <div class="pa-whyx__stat-num">3.4%</div>
            <div class="pa-whyx__stat-lbl">of global biomedical publications</div>
            <div class="pa-whyx__stat-sub">Australia produces output at ~3× its share of world GDP. Source: Nature Index 2024.</div>
          </div>
          <div class="pa-whyx__stat">
            <div class="pa-whyx__stat-num">A$22B</div>
            <div class="pa-whyx__stat-lbl">Medical Research Future Fund</div>
            <div class="pa-whyx__stat-sub">Sovereign endowment for translational research, perpetually invested by the Australian Government.</div>
          </div>
          <div class="pa-whyx__stat">
            <div class="pa-whyx__stat-num pa-whyx__stat-num--neg">0.06%</div>
            <div class="pa-whyx__stat-lbl">of GDP into life‑sciences VC</div>
            <div class="pa-whyx__stat-sub">~1/8th of the US figure. The bottleneck is company formation capital — not science. Source: ABS, NVCA.</div>
          </div>
        </div>
        <div class="pa-whyx__bridge">
          <div class="pa-whyx__bridge-lbl">Our response</div>
          <p class="pa-whyx__bridge-body">
            Permanent capital, milestone‑gated, deployed alongside Australia's research institutions to form companies that wouldn't otherwise exist. <strong>Eight in five years.</strong> Three approaching clinical trials.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Build (5-step) -->
  <section class="pa-section pa-section--brand" style="position: relative; overflow: hidden;">
    <img src="/images/textures/textures_full-circle.svg" alt=""
      style="position: absolute; right: -160px; top: -100px; width: 560px; height: 560px; opacity: 0.14; pointer-events: none;" />
    <div class="pa-wrap" style="position: relative;">
      <div class="pa-build-head">
        <div>
          <div class="pa-eyebrow">How we build companies</div>
          <h2 class="pa-h2" style="margin: 0;">From signal<br/>to scale.</h2>
        </div>
        <p class="pa-build-head__lead">
          We do the hard middle: rigorous diligence, practical company building, and disciplined capital deployment alongside the researchers we partner with — five stages, one operating bench.
        </p>
        <div class="pa-build-head__meta">
          <span>Average time, signal → first capital</span>
          <strong>~9 months</strong>
        </div>
      </div>
      <div class="pa-build-flow">
        <div class="pa-build-row pa-build-row--text">
          {buildSteps.slice(0, 2).map((s, i) => (
            <article class="pa-build-step">
              <div class="pa-build-step__rule"></div>
              <div class="pa-build-step__head">
                <span class="pa-build-step__num">{s.n}</span>
                <span class="pa-build-step__tag">{i === 0 ? 'Sourcing' : 'Diligence'}</span>
              </div>
              <h3 class="pa-build-step__title">{s.title}</h3>
              <p class="pa-build-step__text">{s.text}</p>
            </article>
          ))}
        </div>
        <div class="pa-build-row pa-build-row--anchor">
          <a class="pa-build-anchor-link" href="/applications/challenger">
            <figure class="pa-build-anchor">
              <img src="/images/photography/lab-researchers.jpg" alt="Challenger Summit pitch day, Sydney" />
              <figcaption>
                <span class="pa-build-anchor__lbl">Challenger Summit</span>
                <span class="pa-build-anchor__cap">Australia's largest pitch day in life sciences. Researchers, founders and clinical leads pitch for capital and a path to patient impact &mdash; A$500K in non&#8209;dilutive grants. <strong>Programme details &rarr;</strong></span>
              </figcaption>
            </figure>
          </a>
          <article class="pa-build-step pa-build-step--accent">
            <div class="pa-build-step__rule pa-build-step__rule--accent"></div>
            <div class="pa-build-step__head">
              <span class="pa-build-step__num pa-build-step__num--accent">{buildSteps[2].n}</span>
              <span class="pa-build-step__tag pa-build-step__tag--accent">Formation</span>
            </div>
            <h3 class="pa-build-step__title">{buildSteps[2].title}</h3>
            <p class="pa-build-step__text">{buildSteps[2].text}</p>
            <ul class="pa-build-step__list">
              <li>Founding capital, A$0.8M – A$3.6M</li>
              <li>Company formation &amp; IP licensing</li>
              <li>Tailored management appointment</li>
            </ul>
          </article>
        </div>
        <div class="pa-build-row pa-build-row--text">
          {buildSteps.slice(3).map((s, i) => (
            <article class="pa-build-step">
              <div class="pa-build-step__rule"></div>
              <div class="pa-build-step__head">
                <span class="pa-build-step__num">{s.n}</span>
                <span class="pa-build-step__tag">{i === 0 ? 'De‑risking' : 'Scale'}</span>
              </div>
              <h3 class="pa-build-step__title">{s.title}</h3>
              <p class="pa-build-step__text">{s.text}</p>
            </article>
          ))}
        </div>
      </div>
      <div class="pa-build-foot">
        <span class="pa-build-foot__lbl">Outcome</span>
        <p class="pa-build-foot__body">
          A company with a defined development plan, capital sufficient for the next gate, and an operating team that has built biotechs before. Repeated, with discipline, eight times since 2021.
        </p>
      </div>
    </div>
  </section>

  <!-- Portfolio -->
  <section class="pa-section pa-section--white" id="portfolio">
    <div class="pa-wrap">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 96px; align-items: end; margin-bottom: 64px;">
        <div>
          <div class="pa-eyebrow">Portfolio · 8 companies</div>
          <h2 class="pa-h2">Scientific breakthroughs, translated.</h2>
        </div>
        <div style="display: flex; flex-direction: column; align-items: flex-start; gap: 16px;">
          <p class="pa-body" style="margin: 0; color: var(--pa-ink-muted); font-size: 17px; max-width: 480px;">
            Eight companies across therapeutics, biotech, diagnostics and bioprocessing — sourced from Australia's leading research institutions and built with Proto Axiom as founding investor.
          </p>
        </div>
      </div>
      <div class="pa-portfolio">
        {portfolio.map((p) => (
          <a class="pa-portfolio__card" href={`/portfolio/${p.slug}`}>
            <div class="pa-portfolio__top">
              <img class="pa-portfolio__logo" src={p.logo} alt={p.name} />
              <div class="pa-portfolio__year">{p.yearFounded}</div>
            </div>
            <div class="pa-portfolio__sector">{p.sector} · {p.modality}</div>
            <h3 class="pa-portfolio__name">{p.name}</h3>
            <p class="pa-portfolio__tagline">{p.tagline}</p>
            <dl class="pa-portfolio__stats">
              <div><dt>Origin</dt><dd>{p.origin}</dd></div>
              <div><dt>Stage</dt><dd>{p.stage}</dd></div>
              <div>
                <dt>Relationship</dt>
                <dd>{p.relationship === 'founding-investor' ? 'Created with Proto Axiom' : 'Venture stake'}</dd>
              </div>
            </dl>
            <div class="pa-portfolio__foot">
              <span class="pa-portfolio__stage">{p.relationship === 'founding-investor' ? 'Founding investor' : 'Venture'}</span>
              <span class="pa-portfolio__more">View →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- Capital structure -->
  <section class="pa-section pa-section--white">
    <div class="pa-wrap">
      <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 96px; align-items: end; margin-bottom: 56px;">
        <div>
          <div class="pa-eyebrow">Capital structure</div>
          <h2 class="pa-h2">A holding company.<br/>Not a fund.</h2>
        </div>
        <p class="pa-body" style="margin: 0; color: var(--pa-ink-muted); font-size: 17px; max-width: 540px;">
          Most biotech in Australia is funded by closed-end venture funds with a 10-year clock. We're structured for the timelines science actually requires.
        </p>
      </div>
      <div class="pa-capstruct">
        <div class="pa-capstruct__col pa-capstruct__col--pa">
          <div class="pa-capstruct__lbl">Proto Axiom</div>
          <h3 class="pa-capstruct__h">Permanent capital. Milestone-gated.</h3>
          <p class="pa-capstruct__sub">Holding company structure with no fixed life — capital recycles into the portfolio indefinitely.</p>
          <div class="pa-capstruct__rows">
            <div class="pa-capstruct__row"><span>Vehicle</span><div><strong>Holding company</strong> — single permanent balance sheet</div></div>
            <div class="pa-capstruct__row"><span>Time horizon</span><div><strong>Indefinite</strong> — no fund close, no forced exits</div></div>
            <div class="pa-capstruct__row"><span>Fees</span><div><strong>None</strong> — no management fee, no carry</div></div>
            <div class="pa-capstruct__row"><span>Capital release</span><div><strong>Gate-driven</strong> — tranches against scientific milestones</div></div>
            <div class="pa-capstruct__row"><span>Operating bench</span><div><strong>Shared</strong> — clinical, regulatory, IP, finance, governance</div></div>
          </div>
        </div>
        <div class="pa-capstruct__col pa-capstruct__col--vc">
          <div class="pa-capstruct__lbl">Traditional VC fund</div>
          <h3 class="pa-capstruct__h">Closed-end. 10-year cycle.</h3>
          <p class="pa-capstruct__sub">Standard fund-of-funds vehicle with LP commitments, fixed deployment window and forced exit calendar.</p>
          <div class="pa-capstruct__rows">
            <div class="pa-capstruct__row"><span>Vehicle</span><div><strong>Limited partnership</strong> — LP commitments, GP carry</div></div>
            <div class="pa-capstruct__row"><span>Time horizon</span><div><strong>10 years</strong> — investment + harvest periods fixed</div></div>
            <div class="pa-capstruct__row"><span>Fees</span><div><strong>2 / 20</strong> — 2% management, 20% carried interest</div></div>
            <div class="pa-capstruct__row"><span>Capital release</span><div><strong>Round-driven</strong> — milestones tied to financing cycles</div></div>
            <div class="pa-capstruct__row"><span>Operating bench</span><div><strong>External</strong> — outsourced to founders / consultants</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Initiatives -->
  <section class="pa-section pa-section--white">
    <div class="pa-wrap">
      <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 96px; align-items: end; margin-bottom: 56px;">
        <div>
          <div class="pa-eyebrow">Initiatives</div>
          <h2 class="pa-h2">Programmes that<br/>widen the funnel.</h2>
        </div>
        <p class="pa-body" style="margin: 0; color: var(--pa-ink-muted); font-size: 17px; max-width: 540px;">
          Alongside our portfolio, Proto Axiom runs and supports programmes that surface translational science earlier — from researchers who haven't yet considered company formation through to under‑represented founders in priority therapeutic areas.
        </p>
      </div>
      <div class="pa-inits">
        <a class="pa-inits__card" href="/applications/challenger">
          <div class="pa-inits__top">
            <div class="pa-inits__lbl">Pitch programme · Annual</div>
            <span class="pa-inits__arrow">→</span>
          </div>
          <h3 class="pa-inits__name">Challenger Summit</h3>
          <p class="pa-inits__desc">Australia's largest pitch day in life sciences. Researchers, founders and clinical leads pitch for capital, mentorship and a path to patient impact. A$500K in grant prizes awarded in 2026.</p>
          <dl class="pa-inits__stats">
            <div><dt>Next event</dt><dd>2027</dd></div>
            <div><dt>2026 prize pool</dt><dd>A$500K</dd></div>
            <div><dt>Partner</dt><dd>St Vincent's Health</dd></div>
          </dl>
        </a>
        <a class="pa-inits__card" href="https://womenshealthfoundry.com.au" target="_blank" rel="noopener">
          <div class="pa-inits__top">
            <div class="pa-inits__lbl">Translation platform · National</div>
            <span class="pa-inits__arrow">↗</span>
          </div>
          <h3 class="pa-inits__name">Women's Health Foundry</h3>
          <p class="pa-inits__desc">A national women's health translation platform being built by Proto Axiom — moving Australian women's health innovations from research into de‑risked, investment‑ready ventures, with academic, clinical, consumer, industry and investor partners.</p>
          <dl class="pa-inits__stats">
            <div><dt>Status</dt><dd>In development</dd></div>
            <div><dt>Scope</dt><dd>National platform</dd></div>
            <div><dt>Visit</dt><dd>womenshealthfoundry.com.au</dd></div>
          </dl>
        </a>
      </div>
    </div>
  </section>

  <!-- Latest news -->
  <section class="pa-section pa-section--white">
    <div class="pa-wrap">
      <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 56px;">
        <div>
          <div class="pa-eyebrow">Latest news</div>
          <h2 class="pa-h2" style="margin: 0;">From the firm and our portfolio.</h2>
        </div>
        <a class="pa-link" href="/news">All news <span style="margin-left: 6px;">→</span></a>
      </div>
      <div class="pa-news">
        {news.slice(0, 3).map((n) => (
          <article class="pa-news__item">
            <div class="pa-news__meta">
              <span>{n.date}</span>
              <span>·</span>
              <span class="pa-news__source">{n.source}</span>
              <span>·</span>
              <span>{n.kind}</span>
            </div>
            <h3 class="pa-news__title">{n.title}</h3>
            <div style="margin-top: auto; padding-top: 16px;">
              <a class="pa-link" href="/news">Read <span style="margin-left: 6px;">→</span></a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
