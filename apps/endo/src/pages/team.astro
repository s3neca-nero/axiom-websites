---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Container } from '@axiom/ui';
import { getCollection } from 'astro:content';

const team = (await getCollection('team')).filter((m) => m.slug !== 'placeholder').sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Team | Endo Axiom">
  <Container>
    <section style="padding: 6rem 0;">
      <p class="eyebrow">Team</p>
      <h1>The people behind Endo Axiom</h1>
      {team.length === 0 || team[0].data.name === 'Placeholder Person' ? (
        <p class="placeholder">
          Team members render here once content is added. Since Wix has no
          clean CMS export, plan to manually transcribe team entries from the
          live site into <code>apps/endo/src/content/team/</code> as markdown.
        </p>
      ) : (
        <ul class="grid">
          {team.map((m) => (
            <li>
              {m.data.photo && <img src={m.data.photo} alt={m.data.name} />}
              <strong>{m.data.name}</strong>
              <span>{m.data.role}</span>
            </li>
          ))}
        </ul>
      )}
    </section>
  </Container>
</BaseLayout>

<style>
  .eyebrow { text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.8rem; color: rgb(var(--brand-navy)); }
  h1 { font-size: clamp(2rem, 5vw, 3.5rem); margin: 1rem 0 2rem; }
  .placeholder { padding: 1.5rem; border: 1px dashed rgb(var(--brand-navy) / 0.4); border-radius: 0.5rem; background: rgb(var(--brand-navy) / 0.04); }
  .grid { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 2rem; }
</style>
